<mxfile host="app.diagrams.net">
  <diagram name="LaunchLens Architecture">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="LaunchLens — what you must build (a LangGraph market-intelligence agent)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="760" height="30" as="geometry" />
        </mxCell>
        <mxCell id="u" value="Founder asks a question" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f1f3f4;strokeColor=#9aa0a6;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="320" y="70" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sum" value="summarize node&#10;SHORT-TERM MEMORY: compress long chats" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe9ff;strokeColor=#1a73e8;fontColor=#173a6b;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rt" value="router&#10;ROUTING: classify the ask" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#f9ab00;fontColor=#5f4500;" vertex="1" parent="1">
          <mxGeometry x="310" y="250" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="dem" value="demand branch&#10;(Google Trends)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f3f4;strokeColor=#9aa0a6;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pri" value="pricing branch&#10;(Shopping + Amazon)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f3f4;strokeColor=#9aa0a6;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="310" y="390" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="full" value="full report branch&#10;FAN-OUT: parallel data pulls, then merge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9f2e3;strokeColor=#34a853;fontColor=#0b5132;" vertex="1" parent="1">
          <mxGeometry x="610" y="385" width="220" height="60" as="geometry" />
